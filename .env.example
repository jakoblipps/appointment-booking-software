# =============================================================================
# Open Reception – Environment Configuration
# Copy this file to .env and fill in the values that fit your setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development

# Port the SvelteKit app is exposed on the host (container always uses 3000).
APP_PORT=3000

# Public URL of the app (used for invite links, password reset emails, etc.).
# In production set this to https://your-domain.tld
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of origins allowed for WebAuthn / Passkey logins.
# Must include every origin from which users access the app.
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000

# Used to sign JWTs (sessions, booking access tokens). Generate with:
#   openssl rand -hex 64
JWT_SECRET=devsecretforjwtencryptionchangeforproduction

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=appointment_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_PORT=5432

# Connection string consumed by the app and Drizzle ORM.
# - Inside docker-compose use the service name "postgres" as host.
# - For `npm run dev` against the dev compose use "localhost".
DATABASE_URL=postgres://postgres:changeme_local_only@postgres:5432/appointment_booking

# -----------------------------------------------------------------------------
# SMTP / E-Mail
# Required to send invitations, PIN resets, etc. For local development you can
# point this at MailHog/Mailpit/Mailtrap.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM_NAME=Open Reception
SMTP_FROM_EMAIL=noreply@example.com
